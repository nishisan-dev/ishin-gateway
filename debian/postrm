#!/bin/bash
set -e

case "$1" in
    purge)
        # Remove dados de runtime apenas no purge
        rm -rf /var/log/ishin-gateway
        # Remove user de sistema
        if id -u ishin-gateway >/dev/null 2>&1; then
            userdel ishin-gateway || true
        fi
        ;;
esac

systemctl daemon-reload || true
